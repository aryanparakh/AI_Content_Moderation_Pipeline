{
  "name": "moderation-pipeline-backend",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered content moderation pipeline backend (Claude API)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
