    "typecheck": "tsc -p tsconfig.json --noEmit",
    "evaluate": "tsx src/eval/runEvaluation.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
