# Copy this file to ".env" and fill in your key.
# Get a key from https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
PORT=4000

# Model used for classification (defaults to claude-opus-4-8)
MODERATION_MODEL=claude-opus-4-8

# Set to "false" to disable adaptive thinking on the classifier (faster, cheaper).
MODERATION_THINKING=true
